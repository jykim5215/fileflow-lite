<Window x:Class="FileFlow.Worker.ConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="최종 확인" Width="510" Height="360" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Grid Margin="26">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock Text="파일을 변경할까요?" FontSize="22" FontWeight="SemiBold"/>
        <TextBlock x:Name="SummaryText" Grid.Row="1" Margin="0,8,0,18" Opacity="0.7" TextWrapping="Wrap"/>
        <Border Grid.Row="2" BorderBrush="{StaticResource SubtleStroke}" BorderThickness="1" CornerRadius="8" Background="{StaticResource SubtleFill}" Padding="14">
            <StackPanel>
                <TextBlock Text="✓  기존 파일을 자동으로 덮어쓰지 않습니다." Margin="0,4"/>
                <TextBlock Text="✓  미리보기 후 파일 상태를 다시 검사합니다." Margin="0,4"/>
                <TextBlock Text="✓  작업 로그를 남기고 직전 작업을 취소할 수 있습니다." Margin="0,4"/>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="돌아가기" Padding="16,7" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="적용" Padding="20,7" IsDefault="True" Click="Apply_Click"/>
        </StackPanel>
    </Grid>
</Window>
