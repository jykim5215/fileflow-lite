<Window x:Class="FileFlow.Worker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FileFlow Lite" Width="980" Height="720" MinWidth="820" MinHeight="620"
        WindowStartupLocation="CenterOwner" Background="Transparent" UseLayoutRounding="True">
    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="28,22,28,18">
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <Border Width="42" Height="42" CornerRadius="8" Background="{DynamicResource AccentFillColorDefaultBrush}" VerticalAlignment="Top">
                <TextBlock Text="&#xE8B7;" FontFamily="Segoe Fluent Icons" FontSize="19" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <StackPanel Grid.Column="1" Margin="14,0,0,0">
                <TextBlock x:Name="TitleText" Text="폴더 평탄화" FontSize="22" FontWeight="SemiBold"/>
                <TextBlock x:Name="SubtitleText" Text="파일 탐색기에서 선택한 항목을 안전하게 정리합니다." Opacity="0.65" Margin="0,3,0,0"/>
            </StackPanel>
            <Button Grid.Column="2" Content="직전 작업 취소" Padding="14,7" VerticalAlignment="Center" Click="Undo_Click"/>
        </Grid>

        <Border Grid.Row="1" Margin="28,0,28,16" BorderBrush="{StaticResource SubtleStroke}" BorderThickness="1" CornerRadius="8" Background="{StaticResource SubtleFill}" Padding="16">
            <Grid>
                <Grid x:Name="FlattenOptions">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Text="원본 폴더" VerticalAlignment="Center"/>
                    <TextBox x:Name="SourcePathBox" Grid.Column="1" IsReadOnly="True" Margin="0,0,8,8"/>
                    <TextBlock Grid.Row="1" Text="대상 폴더" VerticalAlignment="Center"/>
                    <TextBox x:Name="DestinationPathBox" Grid.Row="1" Grid.Column="1" IsReadOnly="True" Margin="0,0,8,8"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="선택…" Padding="14,6" Margin="0,0,0,8" Click="ChooseDestination_Click"/>
                    <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal">
                        <TextBlock Text="처리 방식" Width="110" VerticalAlignment="Center"/>
                        <ComboBox x:Name="TransferModeBox" Width="145" SelectedIndex="0" SelectionChanged="Option_Changed"><ComboBoxItem Content="복사 (권장)"/><ComboBoxItem Content="이동"/></ComboBox>
                        <TextBlock Text="이름 충돌" Margin="22,0,10,0" VerticalAlignment="Center"/>
                        <ComboBox x:Name="CollisionModeBox" Width="170" SelectedIndex="0" SelectionChanged="Option_Changed"><ComboBoxItem Content="순번 자동 부여"/><ComboBoxItem Content="폴더명 접두어"/></ComboBox>
                        <CheckBox x:Name="DeleteEmptyBox" Content="빈 폴더 삭제" Margin="22,0,0,0" VerticalAlignment="Center" IsEnabled="False" Checked="Option_Changed" Unchecked="Option_Changed"/>
                    </StackPanel>
                </Grid>

                <Grid x:Name="RenameOptions" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/><ColumnDefinition Width="70"/><ColumnDefinition Width="*"/><ColumnDefinition Width="80"/><ColumnDefinition Width="100"/></Grid.ColumnDefinitions>
                    <TextBlock Text="접두어" VerticalAlignment="Center"/><TextBox x:Name="PrefixBox" Grid.Column="1" Margin="0,0,14,8" TextChanged="Option_Changed"/>
                    <TextBlock Grid.Column="2" Text="접미어" VerticalAlignment="Center"/><TextBox x:Name="SuffixBox" Grid.Column="3" Margin="0,0,14,8" TextChanged="Option_Changed"/>
                    <TextBlock Grid.Column="4" Text="시작 번호" VerticalAlignment="Center"/><TextBox x:Name="StartBox" Grid.Column="5" Text="1" Margin="0,0,0,8" TextChanged="Option_Changed"/>
                    <TextBlock Grid.Row="1" Text="정렬" VerticalAlignment="Center"/><ComboBox x:Name="SortBox" Grid.Row="1" Grid.Column="1" SelectedIndex="0" SelectionChanged="Option_Changed"><ComboBoxItem Content="이름"/><ComboBoxItem Content="수정한 날짜"/><ComboBoxItem Content="크기"/></ComboBox>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="자릿수" VerticalAlignment="Center"/><ComboBox x:Name="PaddingBox" Grid.Row="1" Grid.Column="3" SelectedIndex="1" Width="100" HorizontalAlignment="Left" SelectionChanged="Option_Changed"><ComboBoxItem Content="1"/><ComboBoxItem Content="2"/><ComboBoxItem Content="3"/><ComboBoxItem Content="4"/></ComboBox>
                    <CheckBox x:Name="DescendingBox" Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="2" Content="내림차순" VerticalAlignment="Center" Checked="Option_Changed" Unchecked="Option_Changed"/>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="28,0,28,16">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <Grid>
                <TextBlock Text="실행 전 미리보기" Style="{StaticResource SectionTitle}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="SummaryText" Opacity="0.7" VerticalAlignment="Center"/>
                    <Button Content="새로 고침" Margin="12,0,0,0" Padding="12,5" Click="Refresh_Click"/>
                </StackPanel>
            </Grid>
            <DataGrid x:Name="PreviewGrid" Grid.Row="1" Margin="0,10,0,0" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal" SelectionMode="Extended">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="변경 전" Binding="{Binding Before}" Width="*"/>
                    <DataGridTextColumn Header="변경 후" Binding="{Binding After}" Width="*"/>
                    <DataGridTextColumn Header="상태" Binding="{Binding State}" Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
            <Border x:Name="WarningBar" Grid.Row="2" Background="#18FFB900" CornerRadius="6" Padding="10,7" Margin="0,10,0,0" Visibility="Collapsed">
                <TextBlock x:Name="WarningText" TextWrapping="Wrap"/>
            </Border>
        </Grid>

        <Border Grid.Row="3" BorderBrush="{StaticResource SubtleStroke}" BorderThickness="0,1,0,0" Padding="28,14" Background="{DynamicResource WindowBackgroundBrush}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe Fluent Icons" Margin="0,0,8,0" Foreground="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                    <TextBlock x:Name="StatusText" Text="아직 파일은 변경되지 않았습니다." Opacity="0.72"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="취소" Padding="18,7" Margin="0,0,8,0" Click="Cancel_Click"/>
                    <Button x:Name="ApplyButton" Content="확인하고 적용" Padding="18,7" IsDefault="True" IsEnabled="False" Click="Apply_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
